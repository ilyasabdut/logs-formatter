{
	"manifest_version": 3,
	"name": "Logs Formatter",
	"version": "1.0.0",
	"description": "Privacy-first log formatter and optimizer.",
	"action": {
		"default_popup": "index.html",
		"default_icon": "favicon.png"
	},
	"chrome_url_overrides": {
		"newtab": "index.html"
	},
	"icons": {
		"128": "favicon.png"
	},
	"permissions": ["storage"]
}
